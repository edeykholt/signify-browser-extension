	async Task OpenTabAndClosePopUp()
	{
		if (utilModule is null)
		{
			_logger.LogError("OpenTabAndClosePopUp: utilModule is null!");
			return;
		}
		await UIHelper.NewTabAndClosePopup();
		return;
	}

	async Task Lock()
	{
		// TODO P2 assure state is persisted and close all app or extension tabs.
		// Wouldn't it be better if the navigation be reactive to the change in state?  Such is needed for inactivity timeout anyway.
		// Also, when starting up an application that was recently closed, should it be unlocked? No. Clarify and implement those requirements.
		await stateService.Unauthenticate();
		// IsIdenticonHidden = true;
		StateHasChanged();
		NavManager.NavigateTo(RouteToStart);
	}

	// Set ActiveDid based on value of activeDidIdentifier,
	// retrieved from picker or via preferences
	async Task SetActiveDid()
	{
		isProfilePanelOpen = false;
		var pref = await PreferencesService.GetPreferences();
		pref.SelectedDidIdentifier = (string)activeDidIdentifier;
		await PreferencesService.SetPreferences(pref);
		// Other actions will be reactive. See IObserver<Preferences>
	}

	private void ClickToggleProfilePanel(MouseEventArgs args)
	{
		ToggleProfilePanel();
	}

	void ToggleProfilePanel()
	{
		isProfilePanelOpen = !isProfilePanelOpen;
	}

	void OpenMenuDrawer()
	{
		isMenuDrawerOpen = true;
		UpdateMainContentStyle();
	}

	void ToggleMenuDrawer()
	{
		isMenuDrawerOpen = !isMenuDrawerOpen;
		UpdateMainContentStyle();
	}

	private void GoToChat()
	{
		// TODO P3 Chat: hasNewMessages should be responsive to existence of unread messages, not this click
		hasNewMessages = false;
		NavManager.NavigateTo(RouteToChat);
	}

	private void GoToStart()
	{
		NavManager.NavigateTo(RouteToStart);
	}

